{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(@workflow-platform)/)"
  ],
  "detectOpenHandles": true,
  "forceExit": true,
  "maxWorkers": 1
}