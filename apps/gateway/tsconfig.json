{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@/*": ["./src/*"],
      "@tesseract/types": ["../../packages/types/dist"]
    },
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "incremental": true,
    "strictPropertyInitialization": false,
    "types": ["jest", "node"]
  },
  "include": ["src/**/*", "scripts", "test/**/*.e2e-spec.ts"],
  "exclude": ["node_modules", "dist"]
}
