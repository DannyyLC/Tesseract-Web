{
  "name": "tesseract",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "install:all": "pnpm install",
    "clean": "pnpm -r --if-present run clean",
    "clean:all": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist",
    "build:types": "pnpm --filter @tesseract/types build",
    "build:database": "pnpm --filter @tesseract/database build",
    "build:gateway": "pnpm --filter @tesseract/gateway build",
    "build:web": "dotenv -e .env -- pnpm --filter @tesseract/web-client build",
    "build:all": "pnpm run build:database && pnpm run build:types && pnpm run build:gateway && pnpm run build:web",
    "dev:gateway": "pnpm run build:types && pnpm --filter @tesseract/gateway start:dev",
    "dev:web": "dotenv -e .env -- pnpm --filter @tesseract/web-client dev",
    "prisma:generate": "pnpm --filter @tesseract/database exec prisma generate",
    "prisma:migrate": "pnpm --filter @tesseract/database exec prisma migrate dev",
    "prisma:migrate:deploy": "pnpm --filter @tesseract/database exec prisma migrate deploy",
    "prisma:studio": "pnpm --filter @tesseract/database exec prisma studio",
    "prisma:reset": "pnpm --filter @tesseract/database exec prisma migrate reset",
    "prisma:seed": "pnpm dlx ts-node packages/database/prisma/seed.ts",
    "test:all": "pnpm -r --if-present run test",
    "test:gateway": "pnpm --filter @tesseract/gateway test",
    "lint": "pnpm -r --if-present run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "format:web": "pnpm --filter @tesseract/web-client exec prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:web:check": "pnpm --filter @tesseract/web-client exec prettier --check \"**/*.{ts,tsx,json,md}\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "docker:clean": "docker-compose down -v && docker system prune -f"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "22.0.1",
    "@nx/eslint-plugin": "22.0.1",
    "@nx/jest": "22.0.1",
    "@nx/js": "22.0.1",
    "@nx/node": "22.0.1",
    "@nx/web": "22.0.1",
    "@nx/webpack": "22.0.1",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.4",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "nx": "22.0.1",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.1.7",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.6",
    "@nx/nest": "^22.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/passport-google-oauth20": "^2.0.17",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "kafka": "^0.2.3",
    "kafkajs": "^2.2.4",
    "nodemailer": "^7.0.12",
    "passport-google-oauth20": "^2.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "speakeasy": "^2.0.0",
    "stripe": "^20.1.2",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.3.0"
  }
}
