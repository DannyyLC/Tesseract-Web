# Database
DATABASE_URL="postgresql://user:password@localhost:5432/workflow_db?schema=public"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
TEMP_TOKEN_SECRET="temp-token-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# Frontend URL (para CORS con cookies httpOnly)
FRONTEND_URL="http://localhost:3001"

# ============================================
# AGENTS SERVICE
# ============================================
# LLM APIs (agrega las que uses)
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_API_KEY="..."

# ============================================
# MEDIA PROCESSING (STT + OCR)
# ============================================
# Endpoint OpenAI-compatible (puede ser OpenAI directo o proxy LiteLLM)
MEDIA_PROCESSING_API_BASE_URL="https://api.openai.com/v1"
# API key
MEDIA_PROCESSING_API_KEY="sk-..."
# Modelos globales 
MEDIA_PROCESSING_STT_MODEL="whisper-1"
MEDIA_PROCESSING_STT_FALLBACK_MODEL=""
MEDIA_PROCESSING_OCR_MODEL="gpt-4o"
MEDIA_PROCESSING_OCR_FALLBACK_MODEL="gpt-4o-mini"
MEDIA_PROCESSING_TIMEOUT_MS=30000

# ============================================
# CONVERSATION COMPACTION (Gateway)
# ============================================
