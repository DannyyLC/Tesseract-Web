# Database
DATABASE_URL="postgresql://user:password@localhost:5432/workflow_db?schema=public"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
TEMP_TOKEN_SECRET="temp-token-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Admin Security
ADMIN_API_KEY="change-this-to-a-random-generated-key-for-admin-operations"

# ============================================
# SUPER ADMIN CONFIGURATION
# ULTRA SEGURO - Solo para dueños del sistema
# ============================================
# Para generar esta configuración, ejecuta:
# npx ts-node apps/gateway/src/admin/scripts/generate-super-admin-config.ts
#
# NUNCA subas el archivo .env con estos valores a git!

# JWT Secret especial para super admins (min 32 caracteres)
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SUPER_ADMIN_SECRET="your-ultra-secret-super-admin-jwt-key-must-be-very-long"

# Super Admin #1 (Principal)
SUPER_ADMIN_1_ID=sa-001
SUPER_ADMIN_1_EMAIL=admin@yourdomain.com
# Generar con: node -e "console.log(require('bcrypt').hashSync('your-password', 10))"
SUPER_ADMIN_1_PASSWORD_HASH=$2b$10$...bcrypt.hash.here...
SUPER_ADMIN_1_NAME=John Doe
# SUPER_ADMIN_1_ALLOWED_IPS=192.168.1.100,10.0.0.5 (opcional)

# Puedes agregar hasta 5 super admins (SUPER_ADMIN_2, SUPER_ADMIN_3, etc.)
# SUPER_ADMIN_2_ID=sa-002
# SUPER_ADMIN_2_EMAIL=admin2@yourdomain.com
# SUPER_ADMIN_2_PASSWORD_HASH=$2b$10$...
# SUPER_ADMIN_2_NAME=Jane Smith


# Server
PORT=3000
NODE_ENV=development

# Frontend URL (para CORS con cookies httpOnly)
FRONTEND_URL="http://localhost:3001"

# ============================================
# STRIPE CONFIGURATION
