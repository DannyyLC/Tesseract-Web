COMPACTION_API_BASE_URL="https://api.openai.com/v1"
COMPACTION_API_KEY="sk-..."
COMPACTION_MODEL="gpt-4o-mini"
COMPACTION_TIMEOUT_MS=20000

# Agents Service URL (para comunicación Gateway → Agents)
