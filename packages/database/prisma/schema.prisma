generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CLIENTES (Usuarios/Organizaciones)
// ============================================

model Client {
  id                   String   @id @default(uuid())
  name                 String
  email                String   @unique
  
  // Autenticación JWT (para UI)
  password             String?  // Hash bcrypt de la contraseña
  emailVerified        Boolean  @default(false)
  emailVerificationToken String? @unique
  passwordResetToken   String?  @unique
  passwordResetExpires DateTime?
  twoFactorEnabled     Boolean  @default(false)
  twoFactorSecret      String?  // Para TOTP (Google Authenticator)
  
  // Plan y límites
  plan                 String   @default("free") // "free", "pro", "enterprise"
  maxWorkflows         Int      @default(10)
  maxExecutionsPerDay  Int      @default(100)
  maxApiKeys           Int      @default(3) // Límite de API keys
  
  // Estado y metadata
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime? // Soft delete
  lastLoginAt          DateTime?
  
  // Distribución y región
  shardKey             String?  @default(uuid())
  region               String?  @default("us-central")
  metadata             Json?    // Datos adicionales flexibles
  
  // Relaciones
  workflows            Workflow[]
  apiKeys              ApiKey[]
  refreshTokens        RefreshToken[]
  whatsappConfigs       WhatsAppConfig[]
  
  @@map("clients")
  @@index([email])
  @@index([deletedAt])
  @@index([isActive])
}

// ============================================
// API KEYS
// ============================================
model ApiKey {
  id          String   @id @default(uuid())
  name        String   // "Producción Web", "App Móvil", "Testing"
  keyHash     String   @unique  // Hash bcrypt del API key
  keyPrefix   String   // Primeros 10 chars para búsqueda rápida
  
  // Metadata y uso
  lastUsedAt  DateTime?
  expiresAt   DateTime? // Opcional: keys con expiración
  isActive    Boolean  @default(true)
  
  // Permisos (opcional, para control granular)
  scopes      Json?    // ["workflows:read", "workflows:write", "workflows:execute"]
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // Soft delete
  
  // Relación
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  @@map("api_keys")
  @@index([clientId])
  @@index([keyPrefix])
  @@index([deletedAt])
}

// ============================================
// REFRESH TOKENS (Para sesiones JWT)
// ============================================
model RefreshToken {
  id               String   @id @default(uuid())
  tokenHash        String   @unique  // Hash del refresh token
  
  // Token rotation (familia de tokens)
  familyId         String   // Todos los tokens rotados comparten familyId
  previousTokenHash String? // Hash del token anterior (para detectar reuso)
  
  // Expiración y revocación
  expiresAt        DateTime
  revokedAt        DateTime? // Si se revocó manualmente
  revokedReason    String?   // "logout", "token_reuse_detected", "security"
  
  // información del dispositivo
  userAgent        String?
  ipAddress        String?
  deviceId         String?  // Identificador único del dispositivo
  
  // Timestamps
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime @default(now())
  
  // Relación
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  @@map("refresh_tokens")
  @@index([clientId])
  @@index([familyId])
  @@index([expiresAt])
}

// ============================================
// WORKFLOWS 
// ============================================

model Workflow {
  id                   String   @id @default(uuid())
  name                 String
  description          String?
  
  // Configuración del workflow
  config               Json     // Tipo "n8n" o "custom"
  version              Int      @default(1)
  
  // Estado y scheduling
  isActive             Boolean  @default(true)
  isPaused             Boolean  @default(false)
  schedule             String?  // Cron expression
  timezone             String?  @default("UTC")
  
  // Configuración de ejecución
  timeout              Int      @default(300) // segundos
  maxRetries           Int      @default(3)
  
  // Tipo de trigger
  triggerType          String?  // "api", "schedule", "webhook", "whatsapp"
  
  // Estadísticas
  totalExecutions      Int      @default(0)
  successfulExecutions Int      @default(0)
  failedExecutions     Int      @default(0)
  lastExecutedAt       DateTime?
  avgExecutionTime     Int?     // segundos
  
  // Timestamps
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime? // Soft delete
  
  // Relaciones
  clientId             String
  client               Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  executions           Execution[]
  tags                 Tag[]
  whatsappConfigs      WhatsAppConfig[]
  
  @@map("workflows")
  @@index([clientId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([lastExecutedAt])
  @@index([triggerType])
}

// ============================================
// EXECUTIONS (Historial de ejecuciones)
// ============================================
model Execution {
  id           String   @id @default(uuid())
  
  // Estado y resultado
  status       String   @default("pending") // "pending", "running", "completed", "failed", "cancelled", "timeout"
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  duration     Int?     // segundos
  
  // Resultado y errores
  result       Json?
  error        String?
  errorStack   String?
  
  // Trigger información
  trigger      String   @default("manual") // "manual", "webhook", "schedule", "api", "whatsapp"
  triggerData  Json?    // IP, payload, etc.
  
  // Logs y debugging
  logs         String?
  stepResults  Json?
  
  // Costos
  cost         Float?   @default(0)
  credits      Int?     @default(0)
  
  // Reintentos
  retryCount   Int      @default(0)
  
  // Timestamps
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relación
  workflowId   String
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  @@map("executions")
  @@index([workflowId])
  @@index([status])
  @@index([startedAt])
  @@index([trigger])
}

// ============================================
// TAGS (Organización de workflows)
// ============================================
model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  color     String?    // Hex color para UI
  createdAt DateTime   @default(now())
  workflows Workflow[]
  
  @@map("tags")
}

// ============================================
// WHATSAPP CONFIG (Integración WhatsApp)
// ============================================
model WhatsAppConfig {
  id                String   @id @default(uuid())
  
  // Información del número
  phoneNumber       String   @unique  // "+521234567890"
  displayName       String?
  description       String?
  
  // Configuración del proveedor
  provider          String   // "twilio", "baileys", "whatsapp-business-api"
  credentials       Json     // Encriptado: { apiKey, accountSid, authToken, etc }
  
  // Webhook security
  webhookSecret     String   @default(uuid())
  webhookUrl        String?  // URL donde WhatsApp enviará mensajes
  
  // Baileys específico
  qrCode            String?  // QR code en base64 (temporal)
  qrCodeExpiry      DateTime?
  connectionStatus  String   @default("disconnected") // "connected", "disconnected", "scanning", "connecting"
  lastConnectedAt   DateTime?
  sessionData       Json?    // Credenciales de Baileys (encriptadas)
  
  // Estado
  isActive          Boolean  @default(true)
  
  // Workflow por defecto
  defaultWorkflowId String?
  defaultWorkflow   Workflow? @relation(fields: [defaultWorkflowId], references: [id])
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  
  // Relación
  clientId          String  
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  @@map("whatsapp_configs")
  @@index([phoneNumber])
  @@index([connectionStatus])
  @@index([clientId]) 
  @@index([deletedAt])
}