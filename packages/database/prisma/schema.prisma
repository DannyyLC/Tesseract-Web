generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ORGANIZATIONS (Empresas/Tenants)
// ============================================

model Organization {
  id   String @id @default(uuid())
  name String
  slug String @unique // URL-friendly: "acme-corp"

  // Plan y límites
  plan                String @default("free") // "free", "pro", "enterprise"
  maxUsers            Int    @default(3) // Free: 3, Pro: 10, Enterprise: -1 (ilimitado)
  maxWorkflows        Int    @default(5) // Free: 5, Pro: 50, Enterprise: -1
  maxExecutionsPerDay Int    @default(100) // Free: 100, Pro: 10000, Enterprise: -1
  maxApiKeys          Int    @default(2) // Free: 2, Pro: 10, Enterprise: -1

  // Estado y metadata
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Distribución y región
  shardKey String? @default(uuid())
  region   String? @default("us-central")
  metadata Json? // Datos adicionales flexibles

  // Billing (opcional para futuro)
  stripeCustomerId   String?   @unique
  subscriptionStatus String?   @default("active") // "active", "cancelled", "past_due"
  subscriptionEndsAt DateTime?

  // Relaciones
  users           User[]
  workflows       Workflow[]
  executions      Execution[]
  apiKeys         ApiKey[]
  whatsappConfigs WhatsAppConfig[]
  auditLogs       AuditLog[]

  @@index([slug])
  @@index([deletedAt])
  @@index([isActive])
  @@index([plan])
  @@map("organizations")
}

// ============================================
// USERS (Empleados con Roles)
// ============================================

model User {
  id    String @id @default(uuid())
  email String @unique
  name  String

  // Autenticación JWT (para UI/Dashboard)
  password               String // Hash bcrypt de la contraseña
  emailVerified          Boolean   @default(false)
  emailVerificationToken String?   @unique
  passwordResetToken     String?   @unique
  passwordResetExpires   DateTime?
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String? // Para TOTP (Google Authenticator)

  // Rol en la organización
  role String @default("viewer") // "owner", "admin", "viewer"

  // Estado y metadata
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft delete
  lastLoginAt DateTime?

  // Avatar y perfil
  avatar   String?
  timezone String? @default("UTC")

  // Relaciones
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens    RefreshToken[]
  executionsManual Execution[] // Ejecuciones manuales desde dashboard

  @@index([email])
  @@index([organizationId])
  @@index([role])
  @@index([deletedAt])
  @@index([isActive])
  @@map("users")
}

// ============================================
// CLIENTES (DEPRECATED - Mantener temporalmente para migración)
// ============================================

model Client {
  id    String @id @default(uuid())
  name  String
  email String @unique

  // Autenticación JWT (para UI)
  password               String? // Hash bcrypt de la contraseña
  emailVerified          Boolean   @default(false)
  emailVerificationToken String?   @unique
  passwordResetToken     String?   @unique
  passwordResetExpires   DateTime?
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String? // Para TOTP (Google Authenticator)

  // Plan y límites
  plan                String @default("free") // "free", "pro", "enterprise"
  maxWorkflows        Int    @default(10)
  maxExecutionsPerDay Int    @default(100)
  maxApiKeys          Int    @default(3) // Límite de API keys

  // Estado y metadata
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft delete
  lastLoginAt DateTime?

  // Distribución y región
  shardKey String? @default(uuid())
  region   String? @default("us-central")
  metadata Json? // Datos adicionales flexibles

  // Relaciones (mantener temporalmente)
  workflows       Workflow[]       @relation("ClientWorkflows")
  apiKeys         ApiKey[]         @relation("ClientApiKeys")
  refreshTokens   RefreshToken[]   @relation("ClientRefreshTokens")
  whatsappConfigs WhatsAppConfig[] @relation("ClientWhatsAppConfigs")

  @@index([email])
  @@index([deletedAt])
  @@index([isActive])
  @@map("clients")
}

// ============================================
// API KEYS (Credenciales de acceso programático)
// ============================================
model ApiKey {
  id          String  @id @default(uuid())
  name        String // "Production Web", "Mobile App", "Testing"
  description String? // Descripción opcional
  keyHash     String  @unique // Hash bcrypt del API key
  keyPrefix   String // Primeros 16 chars para búsqueda rápida

  // Metadata y uso
  lastUsedAt DateTime?
  expiresAt  DateTime? // Opcional: keys con expiración
  isActive   Boolean   @default(true)

  // Permisos opcionales (null = acceso a todos los workflows)
  scopes Json? // { "workflowIds": ["uuid1", "uuid2"] } o null

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Relaciones
  organizationId String? // Temporal nullable para migración
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions     Execution[] // Ejecuciones realizadas por esta API key

  // Relación legacy (temporal)
  clientId String?
  client   Client? @relation("ClientApiKeys", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([clientId])
  @@index([keyPrefix])
  @@index([deletedAt])
  @@index([isActive])
  @@map("api_keys")
}

// ============================================
// REFRESH TOKENS (Para sesiones JWT)
// ============================================
model RefreshToken {
  id        String @id @default(uuid())
  tokenHash String @unique // Hash del refresh token

  // Token rotation (familia de tokens)
  familyId          String // Todos los tokens rotados comparten familyId
  previousTokenHash String? // Hash del token anterior (para detectar reuso)

  // Expiración y revocación
  expiresAt     DateTime
  revokedAt     DateTime? // Si se revocó manualmente
  revokedReason String? // "logout", "token_reuse_detected", "security"

  // información del dispositivo
  userAgent String?
  ipAddress String?
  deviceId  String? // Identificador único del dispositivo

  // Timestamps
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  // Relaciones
  userId String? // Temporal nullable para migración
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relación legacy (temporal)
  clientId String?
  client   Client? @relation("ClientRefreshTokens", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// WORKFLOWS 
// ============================================

model Workflow {
  id          String  @id @default(uuid())
  name        String
  description String?

  // Configuración del workflow
  config  Json // Tipo "n8n" o "custom"
  version Int  @default(1)

  // Estado y scheduling
  isActive Boolean @default(true)
  isPaused Boolean @default(false)
  schedule String? // Cron expression
  timezone String? @default("UTC")

  // Configuración de ejecución
  timeout    Int @default(300) // segundos
  maxRetries Int @default(3)

  // Tipo de trigger
  triggerType String? // "api", "schedule", "webhook", "whatsapp"

  // Estadísticas
  totalExecutions      Int       @default(0)
  successfulExecutions Int       @default(0)
  failedExecutions     Int       @default(0)
  lastExecutedAt       DateTime?
  avgExecutionTime     Int? // segundos

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Relaciones
  organizationId  String? // Temporal nullable para migración
  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions      Execution[]
  tags            Tag[]
  whatsappConfigs WhatsAppConfig[]

  // Relación legacy (temporal)
  clientId String?
  client   Client? @relation("ClientWorkflows", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([clientId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([lastExecutedAt])
  @@index([triggerType])
  @@map("workflows")
}

// ============================================
// EXECUTIONS (Historial de ejecuciones)
// ============================================
model Execution {
  id String @id @default(uuid())

  // Estado y resultado
  status     String    @default("pending") // "pending", "running", "completed", "failed", "cancelled", "timeout"
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  duration   Int? // segundos

  // Resultado y errores
  result     Json?
  error      String?
  errorStack String?

  // Trigger información
  trigger     String @default("manual") // "manual", "webhook", "schedule", "api", "whatsapp"
  triggerData Json? // IP, payload, etc.

  // Logs y debugging
  logs        String?
  stepResults Json?

  // Costos
  cost    Float? @default(0)
  credits Int?   @default(0)

  // Reintentos
  retryCount Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tracking de quién ejecutó (para analytics)
  apiKeyId String? // Si fue ejecutado por API key
  apiKey   ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  userId String? // Si fue ejecución manual desde dashboard
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Multi-tenant: todas las ejecuciones pertenecen a una organización
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relación con workflow
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([organizationId])
  @@index([apiKeyId])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@index([trigger])
  @@map("executions")
}

// ============================================
// TAGS (Organización de workflows)
// ============================================
model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  color     String? // Hex color para UI
  createdAt DateTime   @default(now())
  workflows Workflow[]

  @@map("tags")
}

// ============================================
// WHATSAPP CONFIG (Integración WhatsApp)
// ============================================
model WhatsAppConfig {
  id String @id @default(uuid())

  // Información del número
  phoneNumber String  @unique // "+521234567890"
  displayName String?
  description String?

  // Configuración del proveedor
  provider    String // "twilio", "baileys", "whatsapp-business-api"
  credentials Json // Encriptado: { apiKey, accountSid, authToken, etc }

  // Webhook security
  webhookSecret String  @default(uuid())
  webhookUrl    String? // URL donde WhatsApp enviará mensajes

  // Baileys específico
  qrCode           String? // QR code en base64 (temporal)
  qrCodeExpiry     DateTime?
  connectionStatus String    @default("disconnected") // "connected", "disconnected", "scanning", "connecting"
  lastConnectedAt  DateTime?
  sessionData      Json? // Credenciales de Baileys (encriptadas)

  // Estado
  isActive Boolean @default(true)

  // Workflow por defecto
  defaultWorkflowId String?
  defaultWorkflow   Workflow? @relation(fields: [defaultWorkflowId], references: [id])

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relaciones
  organizationId String? // Temporal nullable para migración
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relación legacy (temporal)
  clientId String?
  client   Client? @relation("ClientWhatsAppConfigs", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([phoneNumber])
  @@index([connectionStatus])
  @@index([organizationId])
  @@index([clientId])
  @@index([deletedAt])
  @@map("whatsapp_configs")
}

// ============================================
// AUDIT LOGS (Solo para Super Admins)
// ============================================
model AuditLog {
  id String @id @default(uuid())

  // Quién realizó la acción
  superAdminId    String // ID del super admin (de config, no FK)
  superAdminEmail String
  superAdminName  String

  // Qué acción realizó
  action     String // "view_organization", "change_plan", "impersonate_user", etc.
  resource   String // "Organization", "User", "Workflow", etc.
  resourceId String? // ID del recurso afectado
  method     String // "GET", "POST", "PATCH", "DELETE"
  endpoint   String // "/admin/organizations/:id"

  // Detalles de la acción
  changes  Json? // { before: {...}, after: {...} }
  metadata Json? // Información adicional relevante

  // Seguridad
  ipAddress String
  userAgent String?

  // Resultado
  statusCode   Int // 200, 404, 500, etc.
  success      Boolean @default(true)
  errorMessage String? // Si hubo error

  // Timing
  duration  Int? // Milisegundos que tardó la operación
  timestamp DateTime @default(now())

  // Organización afectada (si aplica)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([superAdminEmail])
  @@index([action])
  @@index([timestamp])
  @@index([organizationId])
  @@index([success])
  @@map("audit_logs")
}
