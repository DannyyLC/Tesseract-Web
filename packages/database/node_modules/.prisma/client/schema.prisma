generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ORGANIZATION (Tenant principal)
// ============================================
model Organization {
  id   String @id @default(uuid())
  name String
  slug String @unique
  plan String @default("free")

  // Límites según plan
  maxUsers            Int @default(3)
  maxWorkflows        Int @default(5)
  maxExecutionsPerDay Int @default(100)
  maxApiKeys          Int @default(2)

  // Estado
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Escalabilidad futura
  shardKey String? @default(uuid())
  region   String? @default("us-central")
  metadata Json?

  // Billing (Stripe)
  stripeCustomerId   String?   @unique
  subscriptionStatus String?   @default("active")
  subscriptionEndsAt DateTime?

  // Relaciones
  users           User[]
  apiKeys         ApiKey[]
  workflows       Workflow[]
  executions      Execution[]
  tenantTools     TenantTool[]
  whatsappConfigs WhatsAppConfig[]
  auditLogs       AuditLog[]
  endUsers        EndUser[]

  @@index([slug])
  @@index([deletedAt])
  @@index([isActive])
  @@index([plan])
  @@map("organizations")
}

// ============================================
// USER (Empleado de una Organization)
// ============================================
model User {
  id       String @id @default(uuid())
  email    String @unique
  name     String
  password String

  // Verificación
  emailVerified          Boolean @default(false)
  emailVerificationToken String? @unique

  // Reset password
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  // 2FA
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  // Rol y estado
  role     String  @default("viewer") // viewer, editor, admin, owner
  isActive Boolean @default(true)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  lastLoginAt DateTime?

  // Preferencias
  avatar   String?
  timezone String? @default("UTC")

  // Relación con Organization
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relaciones
  refreshTokens    RefreshToken[]
  executionsManual Execution[]
  conversations    Conversation[]

  @@index([email])
  @@index([organizationId])
  @@index([role])
  @@index([deletedAt])
  @@index([isActive])
  @@map("users")
}

// ============================================
// END USER (Cliente externo del negocio)
// ============================================
model EndUser {
  id String @id @default(uuid())

  // Identificadores flexibles
  phoneNumber String? // Para WhatsApp
  email       String? // Para web/email
  externalId  String? // ID del sistema del cliente (ej: HubSpot contact ID)
  sessionId   String? // Para usuarios anónimos

  // Información del usuario
  name     String?
  avatar   String?
  metadata Json? // Datos adicionales flexibles

  // Timestamps
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime?

  // Relación con Organization (multi-tenancy)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relaciones
  conversations Conversation[]

  @@unique([organizationId, phoneNumber])
  @@unique([organizationId, email])
  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@index([phoneNumber])
  @@index([email])
  @@index([sessionId])
  @@index([lastSeenAt])
  @@map("end_users")
}

// ============================================
// CONVERSATION (Sesión de chat)
// ============================================
model Conversation {
  id String @id @default(uuid())

  // USUARIO INTERNO (empleado usando dashboard) - OPCIONAL
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // USUARIO EXTERNO (cliente final) - OPCIONAL
  endUserId String?
  endUser   EndUser? @relation(fields: [endUserId], references: [id], onDelete: Cascade)

  // REGLA DE NEGOCIO: Uno de los dos debe existir (userId o endUserId), pero NO ambos  
  // Workflow/Agente relacionado
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // Metadata de la conversación
  title   String? // "Consulta sobre productos", "Testing agente ventas"
  channel String // 'dashboard', 'whatsapp', 'web', 'api'
  status  String  @default("active") // 'active', 'closed', 'archived'

  // Información adicional
  metadata Json? // Tags, categorías, sentimiento, etc.
  summary  String? // Resumen generado por IA

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime? // Cuándo se cerró la conversación

  // Relaciones
  messages Message[] // Una conversación tiene muchos mensajes

  @@index([userId])
  @@index([endUserId])
  @@index([workflowId])
  @@index([status])
  @@index([channel])
  @@index([createdAt])
  @@map("conversations")
}

// ============================================
// MESSAGE (Mensaje individual)
// ============================================
model Message {
  id String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role String // 'user', 'assistant', 'system', 'tool'

  content     String // Texto del mensaje (siempre presente)
  attachments Json? // Array de archivos multimedia (opcional)

  // Estructura de attachments:
  // [
  //   {
  //     "type": "image",           // image, audio, video, document
  //     "url": "https://...",      // URL del archivo (S3, GCS, etc.)
  //     "mimeType": "image/jpeg",  // Tipo MIME
  //     "filename": "foto.jpg",    // Nombre original
  //     "size": 1024000,           // Tamaño en bytes
  //     "metadata": {              // Metadata específica del tipo
  //       "width": 1920,
  //       "height": 1080,
  //       "duration": 30           // Para audio/video
  //     }
  //   }
  // ]

  metadata Json?

  // Datos de IA (si es respuesta del asistente)
  model     String?
  tokens    Int?
  cost      Float?
  latencyMs Int?

  // Tool calls
  toolCalls   Json?
  toolResults Json?

  createdAt DateTime @default(now())

  // Feedback del usuario
  feedback        String?
  feedbackComment String?

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
  @@map("messages")
}

// ============================================
// TENANT TOOL (Conexiones con servicios externos)
// ============================================
model TenantTool {
  id String @id @default(uuid())

  // Identificación
  toolName    String // "hubspot", "google_calendar", "slack", etc.
  displayName String? // "Mi HubSpot de Ventas"

  // Credenciales (referencia a Secret Manager)
  credentialPath String? // "projects/tesseract/secrets/org-123-hubspot"

  // Configuración específica del tenant (NO secretos)
  config Json? // { "portal_id": "123", "default_pipeline": "ventas" }

  // Estado de conexión
  isConnected     Boolean   @default(false)
  connectionError String? // Último error si falló
  connectedAt     DateTime?
  lastUsedAt      DateTime?

  // Metadata OAuth (para refresh tokens)
  oauthProvider  String? // "google", "microsoft", "hubspot"
  tokenExpiresAt DateTime? // Cuándo expira el access token

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, toolName]) // Un org, una conexión por tool
  @@index([organizationId])
  @@index([toolName])
  @@index([isConnected])
  @@map("tenant_tools")
}

// ============================================
// API KEY
// ============================================
model ApiKey {
  id          String  @id @default(uuid())
  name        String
  description String?

  // Key hasheada (nunca guardamos la key en texto plano)
  keyHash   String @unique
  keyPrefix String // Primeros caracteres para identificar

  // Estado y uso
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?

  // Permisos
  scopes Json? // ["workflows:read", "workflows:execute"]

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relación
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Tracking
  executions Execution[]

  @@index([organizationId])
  @@index([keyPrefix])
  @@index([deletedAt])
  @@index([isActive])
  @@map("api_keys")
}

// ============================================
// REFRESH TOKEN
// ============================================
model RefreshToken {
  id        String @id @default(uuid())
  tokenHash String @unique

  // Familia de tokens (para detectar reuso)
  familyId          String
  previousTokenHash String?

  // Expiración y revocación
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?

  // Metadata del dispositivo
  userAgent String?
  ipAddress String?
  deviceId  String?

  // Timestamps
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  // Relación
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// WORKFLOW (Agente)
// ============================================
model Workflow {
  id          String  @id @default(uuid())
  name        String
  description String?

  // Configuración del agente
  config Json // { system_prompt, model, temperature, etc. }

  // Tools habilitadas para este workflow
  enabledTools String[] @default([]) // ["hubspot", "google_calendar"]

  // Versionado
  version Int @default(1)

  // Estado
  isActive Boolean @default(true)
  isPaused Boolean @default(false)

  // Programación
  schedule    String? // Cron expression
  timezone    String? @default("UTC")
  triggerType String? // "api", "schedule", "webhook", "whatsapp"

  // Configuración de ejecución
  timeout    Int @default(300)
  maxRetries Int @default(3)

  // Estadísticas
  totalExecutions      Int       @default(0)
  successfulExecutions Int       @default(0)
  failedExecutions     Int       @default(0)
  lastExecutedAt       DateTime?
  avgExecutionTime     Int?

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relación
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relaciones
  executions      Execution[]
  whatsappConfigs WhatsAppConfig[]
  tags            Tag[]            @relation("TagToWorkflow")
  conversations   Conversation[]

  @@index([organizationId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([lastExecutedAt])
  @@index([triggerType])
  @@map("workflows")
}

// ============================================
// EXECUTION (Ejecución de un workflow)
// ============================================
model Execution {
  id String @id @default(uuid())

  // Estado
  status String @default("pending") // pending, running, completed, failed, cancelled, timeout

  // Tiempos
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  duration   Int? // En segundos

  // Resultado
  result     Json?
  error      String?
  errorStack String?

  // Trigger
  trigger     String @default("manual") // manual, api, schedule, webhook, whatsapp
  triggerData Json?

  // Debug
  logs        String?
  stepResults Json?

  // Costos
  cost    Float? @default(0)
  credits Int?   @default(0)

  // Reintentos
  retryCount Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Quién lo ejecutó (opcional)
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  apiKeyId String?
  apiKey   ApiKey? @relation(fields: [apiKeyId], references: [id])

  @@index([workflowId])
  @@index([organizationId])
  @@index([apiKeyId])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@index([trigger])
  @@map("executions")
}

// ============================================
// TAG
// ============================================
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())

  workflows Workflow[] @relation("TagToWorkflow")

  @@map("tags")
}

// ============================================
// WHATSAPP CONFIG
// ============================================
model WhatsAppConfig {
  id String @id @default(uuid())

  // Identificación
  phoneNumber String  @unique
  displayName String?
  description String?

  // Proveedor (baileys, twilio, meta)
  provider String

  // Credenciales (referencia a Secret Manager en producción)
  credentialPath String?

  // Webhook
  webhookSecret String  @default(uuid())
  webhookUrl    String?

  // Estado de conexión
  connectionStatus String    @default("disconnected")
  lastConnectedAt  DateTime?
  connectionError  String?

  // QR (para baileys)
  qrCode       String?
  qrCodeExpiry DateTime?

  // Sesión
  sessionData Json?

  // Estado
  isActive Boolean @default(true)

  // Workflow por defecto para mensajes entrantes
  defaultWorkflowId String?
  defaultWorkflow   Workflow? @relation(fields: [defaultWorkflowId], references: [id])

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relación
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([phoneNumber])
  @@index([connectionStatus])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("whatsapp_configs")
}

// ============================================
// AUDIT LOG
// ============================================
model AuditLog {
  id String @id @default(uuid())

  // Quién hizo la acción (superadmin)
  superAdminId    String
  superAdminEmail String
  superAdminName  String

  // Qué hizo
  action     String // create, update, delete, login, etc.
  resource   String // organization, user, workflow, etc.
  resourceId String?

  // Request
  method   String // GET, POST, PUT, DELETE
  endpoint String

  // Cambios
  changes  Json? // { before: {}, after: {} }
  metadata Json?

  // Contexto
  ipAddress String
  userAgent String?

  // Resultado
  statusCode   Int
  success      Boolean @default(true)
  errorMessage String?
  duration     Int? // En ms

  // Timestamp
  timestamp DateTime @default(now())

  // Relación opcional
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([superAdminEmail])
  @@index([action])
  @@index([timestamp])
  @@index([organizationId])
  @@index([success])
  @@map("audit_logs")
}
