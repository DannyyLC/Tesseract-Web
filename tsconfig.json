{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "incremental": true,
    "baseUrl": "./",
    "paths": {
      "@tesseract/database": ["./packages/database/src"],
      "@tesseract/types": ["packages/types/src"]
    },
    "outDir": "./dist"
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
